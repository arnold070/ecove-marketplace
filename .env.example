# 
═══════════════════════════════════════════════════════════ 
# ECOVE MARKETPLACE — ENVIRONMENT VARIABLES # Copy this to .env.local and 
fill in all values before deploying # On VPS: this file lives at 
/var/www/ecove/.env.local # 
═══════════════════════════════════════════════════════════


# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://ecove.com.ng
NEXT_PUBLIC_APP_NAME="Ecove Marketplace"
NODE_ENV=production

# ── DATABASE (PostgreSQL — installed on same VPS) ───────────
# The server-setup.sh script creates these credentials automatically
# Check /root/db-credentials.txt after running the setup script
DATABASE_URL="postgresql://ecove_user:YOUR_DB_PASSWORD@localhost:5432/ecove_db"

# ── AUTH 
─────────────────────────────────────────────# 
# Generate JWT secret using:
# node -e 
"console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-minimum-48-character-random-string-here
JWT_EXPIRES_IN=7d

# ── CLOUDINARY (Image Uploads) ───────────────────────────────
# https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── PAYSTACK (Primary Payment) ───────────────────────────────
# https://dashboard.paystack.com → Settings → API Keys → Live KeyPAYSTACK_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_WEBHOOK_SECRET=your-xxxxxxxxxxxxxxxxxx

# ── FLUTTERWAVE (Optional Secondary Payment) ─────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxx

# ── EMAIL (SMTP) ─────────────────────────────────────────────
# Works with: Hostinger, Zoho, Gmail App Password
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@ecove.com.ng
SMTP_PASS=your-email-password
EMAIL_FROM="Ecove Marketplace <noreply@ecove.com.ng>"
ADMIN_EMAIL=admin@ecove.com.ng

# ── REDIS (installed on same VPS by server-setup.sh) ─────────
REDIS_URL=redis://localhost:6379

# ── SEED CREDENTIALS ─────────────────────────────────────────
# Used only when running: npm run db:seed
# Change the password immediately after first login
SEED_ADMIN_EMAIL=admin@ecove.com.ng
SEED_ADMIN_PASSWORD=Admin@Ecove2025!

# ── SENTRY (Optional — Error Monitoring) ─────────────────────
# https://sentry.io → Free tier → New Project → Next.js
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=ecove-marketplace

# ── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=info
